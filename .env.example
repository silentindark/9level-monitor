# Asterisk AMI connection
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USER=9level
AMI_SECRET=your_ami_secret

# Asterisk ARI connection
ARI_BASE_URL=http://127.0.0.1:8088/ari
ARI_USER=9level
ARI_PASS=your_ari_password

# Collector settings
PORT=3001
DB_PATH=/data/9level.db
RTP_POLL_INTERVAL=30s
ENDPOINT_REFRESH_INTERVAL=5m

# Security: comma-separated IPs to ignore in security events
SECURITY_WHITELIST_IPS=
